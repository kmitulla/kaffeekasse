rules_version = '2';

// ============================================================
// Kaffeekasse – Firestore Sicherheitsregeln
// Diese Regeln schützen deine Daten, auch wenn der API-Key
// öffentlich im Code steht (das ist bei Firebase normal).
// Einfügen unter: Firebase Console > Firestore Database > Regeln
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Der Master schaltet neue Konten frei. Muss identisch sein mit
    // MASTER_EMAIL in js/firebase-config.js!
    function isMaster() {
      return signedIn() && request.auth.token.email == 'k.mitulla@gmail.com';
    }

    // Nur vom Master freigeschaltete Konten duerfen die App nutzen.
    function isApproved() {
      return signedIn() && (
        isMaster()
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true
      );
    }

    function memberDoc(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    function isMember(teamId) {
      return isApproved()
        && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
        && memberDoc(teamId).data.active == true;
    }

    function roleOf(teamId) {
      return memberDoc(teamId).data.role;
    }

    // "Benutzer" (owner) hat alle Rechte, Admin die meisten
    function isAdmin(teamId) {
      return isMember(teamId) && roleOf(teamId) in ['owner', 'admin'];
    }

    function isOwner(teamId) {
      return isMember(teamId) && roleOf(teamId) == 'owner';
    }

    // ---------- Benutzerprofile ----------
    match /users/{uid} {
      // Jeder sieht nur sein eigenes Profil; der Master sieht alle
      // (fuer die Freischaltung neuer Konten).
      allow get: if signedIn() && (request.auth.uid == uid || isMaster());
      allow list: if isMaster();
      // Neue Konten starten IMMER als "nicht freigeschaltet".
      // Der Master darf Konten (Profile) auch direkt anlegen.
      allow create: if isMaster()
        || (signedIn() && request.auth.uid == uid
            && request.resource.data.approved == false);
      // Nur der Master darf das Feld 'approved' aendern.
      allow update: if isMaster()
        || (signedIn() && request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved']));
      allow delete: if isMaster();
    }

    // ---------- Passwort-vergessen-Anfragen ----------
    // Darf ohne Anmeldung erstellt werden (die Person kommt ja nicht rein).
    // Nur der Master kann die Anfragen sehen und freigeben.
    match /pwResets/{resetId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'requestedAt', 'status'])
        && request.resource.data.status == 'open'
        && request.resource.data.email is string
        && request.resource.data.email.size() > 4
        && request.resource.data.email.size() < 200;
      allow read, update, delete: if isMaster();
    }

    // ---------- Teams ----------
    match /teams/{teamId} {
      // Einzelabruf erlaubt (noetig, um per Einladungscode beizutreten).
      // Abfragen/Auflisten aller Teams ist NICHT erlaubt.
      allow get: if isApproved();
      allow list: if false;
      // Neue Teams darf nur der Master erstellen.
      allow create: if isMaster()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(teamId);
      allow delete: if isOwner(teamId);

      // ---------- Mitglieder ----------
      match /members/{uid} {
        allow read: if signedIn()
          && (request.auth.uid == uid || isMember(teamId));
        // Selbst beitreten (nur als einfacher User), durch Admin/Benutzer,
        // oder: der Team-Ersteller legt sich selbst als 'owner' an.
        allow create: if isApproved() && (
          (request.auth.uid == uid && request.resource.data.role == 'user')
          || isAdmin(teamId)
          || (request.auth.uid == uid
              && request.resource.data.role == 'owner'
              && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid)
        );
        // Admin/Benutzer verwalten Mitglieder; die Rolle 'owner'
        // darf nur der Benutzer (owner) selbst vergeben/aendern.
        // Jeder darf seinen eigenen Anzeigenamen im Team aendern.
        allow update: if signedIn() && (
          (isAdmin(teamId)
            && resource.data.role != 'owner'
            && request.resource.data.role != 'owner')
          || isOwner(teamId)
          || (request.auth.uid == uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']))
        );
        allow delete: if signedIn() && (
          (isAdmin(teamId) && resource.data.role != 'owner')
          || (request.auth.uid == uid && resource.data.role != 'owner')
          || isOwner(teamId)
        );
      }

      // ---------- Ausgaben ----------
      match /expenses/{expenseId} {
        allow read: if isMember(teamId);
        // Jedes Mitglied darf eigene Ausgaben anlegen.
        // Verrechnungen (type 'adjustment', z.B. beim Entfernen
        // eines Mitglieds) darf nur Admin/Benutzer anlegen.
        allow create: if isMember(teamId)
          && request.resource.data.createdBy == request.auth.uid
          && (request.resource.data.type == 'expense' || isAdmin(teamId));
        // Eigene Ausgaben aendern/loeschen; Admin/Benutzer alle.
        allow update, delete: if isMember(teamId)
          && (resource.data.createdBy == request.auth.uid || isAdmin(teamId));
      }

      // ---------- Presets / Gruppen (z.B. "Team Milch") ----------
      match /presets/{presetId} {
        allow read: if isMember(teamId);
        allow create, update, delete: if isAdmin(teamId);
      }

      // ---------- Ausgleichszahlungen ----------
      match /settlements/{settlementId} {
        allow read: if isMember(teamId);
        // Zahler meldet "bezahlt" (pending) ODER Empfaenger
        // bestaetigt direkt selbst (confirmed). Admin/Benutzer duerfen
        // ausserdem Zahlungen zwischen beliebigen Personen erfassen.
        allow create: if isMember(teamId) && (
          (request.resource.data.status == 'pending'
            && request.resource.data.from == request.auth.uid)
          || (request.resource.data.status == 'confirmed'
            && request.resource.data.to == request.auth.uid)
          || isAdmin(teamId)
        );
        // Der Empfaenger darf eine offene Zahlung bestaetigen;
        // Admin/Benutzer duerfen Zahlungen bearbeiten (Betrag, Status).
        allow update: if isMember(teamId) && (
          (request.auth.uid == resource.data.to
            && resource.data.status == 'pending'
            && request.resource.data.status == 'confirmed'
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'confirmedAt']))
          || (isAdmin(teamId)
              && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['amount', 'status', 'confirmedAt', 'note']))
        );
        // Zahler darf eigene offene Meldung zurueckziehen; Admin darf loeschen.
        allow delete: if isMember(teamId) && (
          (resource.data.status == 'pending' && resource.data.from == request.auth.uid)
          || isAdmin(teamId)
        );
      }
    }
  }
}
